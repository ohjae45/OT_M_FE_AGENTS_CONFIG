{
  "permissions": {
    "allow": [
      "Bash(pnpm lint*)",
      "Bash(pnpm typecheck*)",
      "Bash(pnpm build*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm exec eslint*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git branch*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty' 2>/dev/null); case \"$FILE\" in *.ts|*.tsx) [ -x node_modules/.bin/eslint ] && pnpm exec eslint --fix \"$FILE\" 2>&1 | head -30 ;; esac"
          }
        ]
      }
    ]
  }
}
